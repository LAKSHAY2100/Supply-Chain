# All values optional. The app runs fully on deterministic mocks if these are blank.

# Gemini Pro (Google AI Studio)
GEMINI_API_KEY=

# Google Maps Platform (Directions / Distance Matrix)
GOOGLE_MAPS_API_KEY=

# OpenWeatherMap (free tier)
OPENWEATHER_API_KEY=

# Firestore service-account JSON path (absolute or relative to backend/)
# If unset, an in-memory store is used.
FIRESTORE_SA_JSON=

# CORS origins (comma-separated). Defaults to http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
